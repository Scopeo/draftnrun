# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API
VITE_SCOPEO_API_URL=
# Set to true to send credentials (cookies) with async run requests e.g. chat/async (useful for local testing)
VITE_RUN_ASYNC_CREDENTIALS=

# App URL (used for OAuth redirects)
VITE_APP_URL=

# Google OAuth for login (Supabase)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_LOGIN_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=

# ⚠️ SECURITY WARNING: The following secrets are exposed in the browser bundle via the VITE_ prefix.
# They should be migrated to a backend proxy in a future ticket.
VITE_GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_LOGIN_CLIENT_SECRET=

# Google OAuth for Drive access
# ⚠️ SECURITY WARNING: Client secret is exposed in the browser bundle.
VITE_GOOGLE_DRIVE_CLIENT_ID=
VITE_GOOGLE_DRIVE_CLIENT_SECRET=

# Google OAuth for Gmail access
# ⚠️ SECURITY WARNING: Client secret is exposed in the browser bundle.
VITE_GOOGLE_GMAIL_CLIENT_ID=
VITE_GOOGLE_GMAIL_CLIENT_SECRET=

# Slack integration
# ⚠️ SECURITY WARNING: Bot/app tokens and client secret are exposed in the browser bundle.
VITE_SLACK_BOT_TOKEN=
VITE_SLACK_APP_TOKEN=
VITE_SLACK_CLIENT_ID=
VITE_SLACK_CLIENT_SECRET=

# Workflow builder (legacy)
VITE_SCOPEO_WORKFLOW_BUILDER_ENDPOINT=
VITE_SCOPEO_WORKFLOW_BUILDER_API_KEY=
VITE_SCOPEO_WORKFLOW_BUILDER_CHAT_ENDPOINT=
VITE_SCOPEO_WORKFLOW_BUILDER_CHAT_API_KEY=

# Google Tag Manager
VITE_GTM_ID=

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=

# Knowledge Editor - Max tokens per chunk (default 8000)
VITE_MAX_CHUNK_TOKENS=
VITE_START_COMPONENT_ID=

# Feature flags
VITE_ENABLE_CHAT_HISTORY=false

# Chat widget
VITE_CHAT_WIDGET_URL=

# Offline mode for local development without internet access
VITE_OFFLINE_MODE=

# Sentry
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# tracePropagationTargets is derived from VITE_API_BASE_URL

# Sentry source map upload (build-time only, not client-exposed)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
